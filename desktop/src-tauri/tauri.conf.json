{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Teak",
  "version": "0.1.0",
  "identifier": "dev.teak.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Teak",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
